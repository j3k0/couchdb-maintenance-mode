#!/bin/bash
set -e

echo "Checking dependencies..."
if ! which whiptail > /dev/null; then
    echo "ERROR: whiptail not found. Please install whiptail or fix your PATH."
    exit 1
fi

if ! which curl > /dev/null; then
    echo "ERROR: curl not found. Please install curl or fix your PATH."
    exit 1
fi

if ! which jq > /dev/null; then
    echo "ERROR: jq not found. Please install jq or fix your PATH."
    exit 1
fi
echo "All good."

if [ -z "$COUCH_URL" ]; then
    echo "Please set \$COUCH_URL to the admin URL (containing user and password)"
    exit 1
fi

COUCHDB_MAINT_LOG="${COUCHDB_MAINT_LOG:-./maintenance_mode.log}"

do_curl() { curl -s -H "Content-type: application/json" "$@"; }

# Fetch all databases and cache design docs
ALL_DBS=()
declare -A DESIGN_DOCS

function load_databases() {
    echo "Loading databases..."
    while IFS= read -r db; do
        ALL_DBS+=("$db")
        DESIGN_DOCS["$db"]=$(do_curl "$COUCH_URL/$db/_design_docs?include_docs=true" 2>/dev/null)
    done < <(do_curl "$COUCH_URL/_all_dbs" | jq -r '.[]')
    echo "Loaded ${#ALL_DBS[@]} databases."
}

function set_auto_update() {
    local DB="$1"
    local DESIGN_DOC="$2"
    local VALUE="$3"

    # Fetch full design doc
    do_curl "$COUCH_URL/$DB/$DESIGN_DOC" > .design_doc

    local CURRENT
    CURRENT=$(jq -r '.options.auto_update // true' .design_doc)

    if [ "$CURRENT" = "$VALUE" ]; then
        echo "$DB/$DESIGN_DOC auto_update already $VALUE"
        return 0
    fi

    # Update the design doc (ensure options object exists)
    local UPDATED
    UPDATED=$(jq ".options.auto_update = $VALUE" .design_doc)

    # PUT and check for errors
    local RESPONSE
    RESPONSE=$(echo "$UPDATED" | do_curl "$COUCH_URL/$DB/$DESIGN_DOC" -X PUT -d @/dev/stdin)
    if echo "$RESPONSE" | jq -e '.error' > /dev/null 2>&1; then
        echo "ERROR: $(echo "$RESPONSE" | jq -r '.error + ": " + .reason')"
        return 1
    fi

    echo "$(date --iso-8601=minutes) $DB/$DESIGN_DOC auto_update $CURRENT -> $VALUE" | tee -a "$COUCHDB_MAINT_LOG"
}

function run_auto_update_menu() {
    # Step 1: Select database
    local DB_MENU=""
    local db_count=0
    for db in "${ALL_DBS[@]}"; do
        local ddoc_json="${DESIGN_DOCS["$db"]}"
        local ddoc_count
        ddoc_count=$(echo "$ddoc_json" | jq -r '.rows | length' 2>/dev/null || echo 0)
        [ "$ddoc_count" = "0" ] && continue
        DB_MENU+="$db \"$ddoc_count design doc(s)\" "
        db_count=$((db_count + 1))
    done
    [ "$db_count" = "0" ] && echo "No databases with design documents found." && return 1
    echo "whiptail --menu \"Select Database\" 20 80 $db_count ${DB_MENU} 2> .target_db" > .db_menu
    chmod +x .db_menu && ./.db_menu
    local SELECTED_DB
    SELECTED_DB=$(cat .target_db)
    [ -z "$SELECTED_DB" ] && return 1

    # Step 2: Select design doc (showing current auto_update value)
    local DESIGN_JSON="${DESIGN_DOCS["$SELECTED_DB"]}"
    local DESIGN_IDS
    DESIGN_IDS=($(echo "$DESIGN_JSON" | jq -r '.rows[].id'))

    local DESIGN_MENU=""
    for d in "${DESIGN_IDS[@]}"; do
        local current
        current=$(echo "$DESIGN_JSON" | jq -r ".rows[] | select(.id == \"$d\") | .doc.options.auto_update // true")
        DESIGN_MENU+="$d \"auto_update=$current\" "
    done
    echo "whiptail --menu \"Select Design Doc ($SELECTED_DB)\" 20 80 ${#DESIGN_IDS[@]} ${DESIGN_MENU} 2> .target_design" > .design_menu
    chmod +x .design_menu && ./.design_menu
    local SELECTED_DESIGN
    SELECTED_DESIGN=$(cat .target_design)
    [ -z "$SELECTED_DESIGN" ] && return 1

    # Step 3: Select value
    local CURRENT_VALUE
    CURRENT_VALUE=$(echo "$DESIGN_JSON" | jq -r ".rows[] | select(.id == \"$SELECTED_DESIGN\") | .doc.options.auto_update // true")
    whiptail --menu "Set auto_update for $SELECTED_DB/$SELECTED_DESIGN (current: $CURRENT_VALUE)" 20 80 2 \
        true  ": Views are updated on every read request" \
        false ": Views are only updated on explicit build request" \
        2> .target_value
    local SELECTED_VALUE
    SELECTED_VALUE=$(cat .target_value)
    [ -z "$SELECTED_VALUE" ] && return 1

    set_auto_update "$SELECTED_DB" "$SELECTED_DESIGN" "$SELECTED_VALUE"
}

# Entry point: CLI mode or interactive mode
if [ "${1:-}" = "set" ] && [ $# -eq 4 ]; then
    # CLI: design_auto_update set <db> <design_doc> <true|false>
    set_auto_update "$2" "$3" "$4"
elif [ "${1:-}" = "toggle" ] && [ $# -eq 3 ]; then
    # CLI: design_auto_update toggle <db> <design_doc>
    do_curl "$COUCH_URL/$2/$3" > .design_doc
    CURRENT=$(jq -r '.options.auto_update // true' .design_doc)
    if [ "$CURRENT" = "true" ]; then
        set_auto_update "$2" "$3" false
    else
        set_auto_update "$2" "$3" true
    fi
else
    load_databases
    while true; do
        run_auto_update_menu || break
        sleep 1
    done
fi
